<%- include('partials/header') %>
<main>
    <h1><%= category.name %></h1>

    <h2>Service Projects</h2>

    <ul>
        <% projects.forEach(project => { %>
            <li>
                <a href="/project/<%= project.project_id %>">
                    <%= project.title %>
                </a>
            </li>
        <% }) %>
    </ul>
    <a class="btn-primary" href="/edit-category/<%= category.category_id %>">Edit</a>
</main>
<%- include('partials/footer') %>
