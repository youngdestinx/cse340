<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <ul>
        <% categories.forEach(category => { %>
            <li>
                <a href="/category/<%= category.category_id %>">
                    <%= category.name %>
                </a>
            </li>
        <% }); %>
    </ul>
    <a class="btn-primary" href="/new-category">Create New Category</a>
</main>
<%- include('partials/footer') %>
